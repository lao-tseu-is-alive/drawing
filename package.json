{
  "name": "drawing",
  "version": "0.0.4",
  "description": "A basic user interface with bun & lit to test simple-2d-geometry ",
  "private": false,
  "type": "module",
  "files": [
    "/dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/drawing.umd.cjs",
  "module": "./dist/drawing.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/drawing.js",
      "require": "./dist/drawing.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "bun index.html",
    "build": "bun run build.ts",
    "check": "bun x tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "format": "prettier --write .",
    "docs": "bun x typedoc --options typedoc.json"
  },
  "keywords": [
    "html",
    "dom",
    "utils",
    "typescript"
  ],
  "author": "CGil<lao.tseu.is.alive@gmail.com>",
  "license": "GNU General Public License v3.0",
  "url": "https://github.com/lao-tseu-is-alive/drawing/issues",
  "homepage": "https://github.com/lao-tseu-is-alive/drawing#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lao-tseu-is-alive/drawing.git"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "lit": "^3.3.2",
    "ts-simple-2d-geometry": "^0.2.0"
  }
}
